<?xml version="1.0"?>
<ruleset name="ZuidWest Cache Manager Coding Standards">
    <description>WordPress Coding Standards for ZuidWest Cache Manager plugin</description>

    <!-- What to scan -->
    <file>zuidwest-cache-manager.php</file>
    <file>includes</file>

    <!-- Exclude vendor directory -->
    <exclude-pattern>vendor/*</exclude-pattern>

    <!-- Arguments -->
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/> <!-- Show sniff codes and progress -->

    <!-- Fix PHP 8 deprecation warnings in PHPCS -->
    <ini name="error_reporting" value="E_ALL &amp; ~E_DEPRECATED"/>

    <!-- WordPress version: 6.8+ -->
    <config name="minimum_wp_version" value="6.8"/>

    <!-- PHP Compatibility: 8.3 to 8.4 -->
    <config name="testVersion" value="8.3-8.4"/>

    <!-- Text domain for i18n -->
    <config name="text_domain" value="zw-cacheman"/>

    <!-- Prefixes for globals -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="zw_cacheman"/>
                <element value="ZW_CACHEMAN"/>
            </property>
        </properties>
    </rule>

    <!-- Use WordPress-Extra as base (includes Core + best practices) -->
    <rule ref="WordPress-Extra">
        <!-- Allow short array syntax -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        <!-- Allow clean filenames for class files (we use OOP) -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
    </rule>

    <!-- PHP Compatibility -->
    <rule ref="PHPCompatibilityWP"/>

    <!-- Line length: allow up to 160 characters, warn after -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="160"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>

    <!-- WordPress documentation standards -->
    <rule ref="WordPress-Docs">
        <!-- PHPStan type aliases aren't real PHP types -->
        <exclude name="Squiz.Commenting.FunctionComment.IncorrectTypeHint"/>
    </rule>
</ruleset>
